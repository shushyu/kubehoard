<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>kubehoard – resource overprovisioning report</title>
<style>
  /* Pastel palette, two accents:
     --acc-blue  = hoarding / overprovisioning
     --acc-green = limit risk */
  :root {
    --fg: #2d3439;
    --fg-muted: #7d8790;
    --bg: #fbfcfd;
    --panel: #ffffff;
    --line: #e4e9ed;
    --bar-track: #eef2f5;
    --bar-req: #c9d7e6;
    --acc-blue: #5f8fc7;
    --acc-blue-soft: #e7eff8;
    --acc-green: #5fa885;
    --acc-green-soft: #e6f2ec;
    --radius: 12px;
    --radius-sm: 7px;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    padding: 44px 28px 80px;
    background: var(--bg);
    color: var(--fg);
    font: 14px/1.55 ui-sans-serif, system-ui, "Segoe UI", Roboto, sans-serif;
  }
  main { max-width: 1080px; margin: 0 auto; }
  h1 { font-size: 24px; font-weight: 700; margin: 0 0 6px; letter-spacing: -.02em; }
  h1 .kube  { color: var(--acc-blue); }
  h1 .hoard { color: var(--acc-green); }
  h2 { font-size: 15px; font-weight: 600; margin: 40px 0 14px; }
  .meta { color: var(--fg-muted); font-size: 13px; margin-bottom: 28px; }
  code, .mono { font-family: ui-monospace, "JetBrains Mono", Menlo, monospace; }

  /* Summary cards */
  .summary { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; }
  .card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 16px 18px;
  }
  .card .label { color: var(--fg-muted); font-size: 12px; }
  .card .value { font-size: 21px; font-weight: 650; margin-top: 3px; }
  .card .sub { color: var(--fg-muted); font-size: 12px; margin-top: 3px; }
  .card.over  { background: var(--acc-blue-soft); border-color: transparent; }
  .card.over .value { color: var(--acc-blue); }
  .card.limit { background: var(--acc-green-soft); border-color: transparent; }
  .card.limit .value { color: var(--acc-green); }

  /* Namespace ranking */
  .ns {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    margin-bottom: 12px;
    overflow: hidden;
  }
  .ns > summary {
    list-style: none; cursor: pointer;
    display: grid; grid-template-columns: 26px minmax(160px, 1.2fr) 2fr auto; gap: 18px;
    align-items: center; padding: 15px 18px;
  }
  .ns > summary::-webkit-details-marker { display: none; }
  .ns > summary:hover { background: #f6f9fb; }
  .rank { color: var(--fg-muted); font-size: 12px; }
  .ns-name { font-weight: 600; word-break: break-all; }
  .ns-sub { color: var(--fg-muted); font-size: 12px; font-weight: 400; }

  .bars { display: grid; gap: 7px; }
  .bar-row { display: grid; grid-template-columns: 34px 1fr; gap: 10px; align-items: center; font-size: 11px; color: var(--fg-muted); }
  .track { position: relative; height: 14px; background: var(--bar-track); border-radius: 999px; overflow: hidden; }
  .track .req, .track .use { position: absolute; top: 0; height: 100%; border-radius: 999px; }
  .track .req { background: var(--bar-req); }
  .track .use { height: 6px; top: 4px; background: var(--acc-blue); }
  .legend { font-size: 11px; color: var(--fg-muted); margin: 10px 0 18px; }
  .legend .swatch { display: inline-block; width: 10px; height: 10px; border-radius: 3px; vertical-align: -1px; margin: 0 4px 0 12px; }

  .badges { display: flex; flex-direction: column; gap: 5px; align-items: flex-end; }
  .badge {
    font-size: 12px; padding: 2px 11px; border-radius: 999px;
    border: 1px solid var(--line); color: var(--fg-muted); white-space: nowrap;
    background: var(--panel);
  }
  .badge.warning  { border-color: transparent; color: var(--acc-blue); background: var(--acc-blue-soft); }
  .badge.critical { border-color: transparent; color: #fff; background: var(--acc-blue); }
  .badge.limit    { border-color: transparent; color: var(--acc-green); background: var(--acc-green-soft); font-weight: 600; }

  /* Pod table in expanded state */
  .table-wrap { overflow-x: auto; } /* fallback: scroll instead of clipping columns */
  table { width: 100%; border-collapse: collapse; font-size: 12px; margin: 0; }
  th, td { text-align: right; padding: 7px 10px; border-top: 1px solid var(--line); white-space: nowrap; }
  th { color: var(--fg-muted); font-weight: 500; background: #f6f9fb; }
  th:first-child, td:first-child { text-align: left; }
  td.pod-name {
    font-family: ui-monospace, Menlo, monospace;
    /* long generated names wrap onto a second line instead of being cut off */
    white-space: normal; word-break: break-word; overflow-wrap: anywhere;
    line-height: 1.35; min-width: 170px; max-width: 300px;
  }
  tr.pod-row td { border-top: 1px solid var(--line); }
  tr.ctr-row td { border-top: none; color: var(--fg-muted); }
  td.ctr-name { padding-left: 26px; }
  .over-name { color: var(--acc-blue); }
  .init-tag { font-size: 10px; border: 1px solid var(--line); border-radius: 999px; padding: 0 6px; color: var(--fg-muted); }
  td.over-hit { color: var(--acc-blue); font-weight: 650; }
  .warnings {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 14px 18px; font-size: 13px; color: var(--fg-muted);
  }
  .warnings li { margin: 3px 0; }
</style>
</head>
<body>
<main>
  <h1><span class="kube">kube</span><span class="hoard">hoard</span></h1>
  <p class="meta">
    Overprovisioning report · generated {{.Report.GeneratedAt.Format "2006-01-02 15:04:05"}}
    {{- if .Report.Server}} · cluster <span class="mono">{{.Report.Server}}</span>{{end}}<br>
    Thresholds: factor ≥ {{printf "%.0f" .Report.Thresholds.WarnFactor}}x warning,
    ≥ {{printf "%.0f" .Report.Thresholds.CritFactor}}x critical ·
    limit utilization ≥ {{printf "%.0f" .Report.Thresholds.LimitWarnPct}}% risk ·
    factor cap {{printf "%.0f" .Report.Thresholds.CapFactor}}x
  </p>

  {{with .Report.Summary}}
  <div class="summary">
    <div class="card">
      <div class="label">Namespaces scanned</div>
      <div class="value">{{.NamespacesScanned}}</div>
      <div class="sub">{{.PodsScanned}} running pods</div>
    </div>
    <div class="card">
      <div class="label">CPU requests vs. usage</div>
      <div class="value">{{fmtCPU .Totals.CPURequestMilli}}</div>
      <div class="sub">actual {{fmtCPU .Totals.CPUUsageMilli}}</div>
    </div>
    <div class="card">
      <div class="label">Memory requests vs. usage</div>
      <div class="value">{{fmtMem .Totals.MemRequestBytes}}</div>
      <div class="sub">actual {{fmtMem .Totals.MemUsageBytes}}</div>
    </div>
    <div class="card over">
      <div class="label">Hoarding namespaces</div>
      <div class="value">{{.HoardersCritical}} critical</div>
      <div class="sub">{{.HoardersWarning}} warning</div>
    </div>
    <div class="card limit">
      <div class="label">Limit risk</div>
      <div class="value">{{.LimitRiskCount}}</div>
      <div class="sub">namespaces close to their limits</div>
    </div>
  </div>
  {{end}}

  <h2>Namespaces by overprovisioning factor</h2>
  <p class="legend">
    Bars scaled relative to the largest namespace:
    <span class="swatch" style="background:var(--bar-req)"></span>request
    <span class="swatch" style="background:var(--acc-blue)"></span>actual usage
  </p>

  {{range $i, $ns := .Namespaces}}
  <details class="ns">
    <summary>
      <span class="rank">{{add1 $i}}</span>
      <span>
        <span class="ns-name">{{$ns.Name}}</span><br>
        <span class="ns-sub">{{$ns.PodsTotal}} pods
          {{- if gt $ns.PodsWithoutMetrics 0}} · {{$ns.PodsWithoutMetrics}} without metrics{{end}} ·
          CPU {{fmtFactor $ns.CPUFactor}} · Mem {{fmtFactor $ns.MemFactor}}</span>
      </span>
      <span class="bars">
        <span class="bar-row"><span>CPU</span>
          <span class="track">
            <span class="req" style="width: {{printf "%.1f" $ns.CPUReqBarPct}}%"></span>
            <span class="use" style="width: {{printf "%.1f" $ns.CPUUseBarPct}}%"></span>
          </span>
        </span>
        <span class="bar-row"><span>Mem</span>
          <span class="track">
            <span class="req" style="width: {{printf "%.1f" $ns.MemReqBarPct}}%"></span>
            <span class="use" style="width: {{printf "%.1f" $ns.MemUseBarPct}}%"></span>
          </span>
        </span>
      </span>
      <span class="badges">
        {{if eq $ns.SeverityString "critical"}}<span class="badge critical">Hoarder {{$ns.FactorLabel}}</span>
        {{else if eq $ns.SeverityString "warning"}}<span class="badge warning">Hoarder {{$ns.FactorLabel}}</span>
        {{else}}<span class="badge">{{$ns.FactorLabel}}</span>{{end}}
        {{if $ns.LimitRisk}}<span class="badge limit">Limit {{fmtPct $ns.MaxPodLimitUtilPct}}</span>{{end}}
      </span>
    </summary>
    <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Pod / container</th>
          <th>CPU req</th><th>CPU lim</th><th>CPU use</th><th>CPU factor</th>
          <th>Mem req</th><th>Mem lim</th><th>Mem use</th><th>Mem factor</th>
        </tr>
      </thead>
      <tbody>
        {{range $ns.Pods}}
        <tr class="pod-row">
          <td class="pod-name {{if podHot .HoardSeverity}}over-name{{end}}">{{.Name}}</td>
          <td>{{fmtCPU .Stats.CPURequestMilli}}</td>
          <td>{{fmtCPULim .Stats.CPULimitMilli}}</td>
          <td>{{fmtCPU .Stats.CPUUsageMilli}}</td>
          <td {{if factorHot .CPUFactor}}class="over-hit"{{end}}>{{fmtFactor .CPUFactor}}</td>
          <td>{{fmtMem .Stats.MemRequestBytes}}</td>
          <td>{{fmtMemLim .Stats.MemLimitBytes}}</td>
          <td>{{fmtMem .Stats.MemUsageBytes}}</td>
          <td {{if factorHot .MemFactor}}class="over-hit"{{end}}>{{fmtFactor .MemFactor}}</td>
        </tr>
        {{range .Containers}}
        <tr class="ctr-row">
          <td class="pod-name ctr-name">└ {{.Name}}{{if .Init}} <span class="init-tag">init</span>{{end}}</td>
          <td>{{fmtCPU .Stats.CPURequestMilli}}</td>
          <td>{{fmtCPULim .Stats.CPULimitMilli}}</td>
          <td>{{fmtCPU .Stats.CPUUsageMilli}}</td>
          <td {{if factorHot .CPUFactor}}class="over-hit"{{end}}>{{fmtFactor .CPUFactor}}</td>
          <td>{{fmtMem .Stats.MemRequestBytes}}</td>
          <td>{{fmtMemLim .Stats.MemLimitBytes}}</td>
          <td>{{fmtMem .Stats.MemUsageBytes}}</td>
          <td {{if factorHot .MemFactor}}class="over-hit"{{end}}>{{fmtFactor .MemFactor}}</td>
        </tr>
        {{end}}
        {{end}}
      </tbody>
    </table>
    </div>
  </details>
  {{end}}

  {{if .Report.Warnings}}
  <h2>Notes</h2>
  <div class="warnings">
    <ul>
      {{range .Report.Warnings}}<li>{{.}}</li>{{end}}
    </ul>
  </div>
  {{end}}
</main>
</body>
</html>
